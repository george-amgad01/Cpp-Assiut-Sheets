#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n  ; cin >> n;
    ll arr[n];
    ll cnt = 0 ; ll cnt2 = 0 ;
    for(ll i=0;i<n;i++) {
        cin >> arr[i];
    }
    for(ll i=0;i<n;i++) {
        if (arr[i] > 0 ) {cnt +=arr[i];}
        if (arr[i] == -1 && cnt == 0) {cnt2 +=1;}
        else if (arr[i] == -1 && cnt > 0) {cnt -=1 ;}
    }
    cout << cnt2 ;
}

int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}

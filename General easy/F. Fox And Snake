#include <iostream>
#include <bits/stdc++.h>
#define ll long long
using namespace std ;
int main () {
    ios_base :: sync_with_stdio(false);cin.tie(0);cout.tie(0);
    ll n , m ; cin >> n >> m ;
    char arr [n][m] ;
    for (int i = 0 ; i < n ; ++i) {
        for (int j = 0 ; j < m; ++j) {
            if (i%2 == 0 ) { arr[i][j] = '#' ;}
            else if (i ==1) {
                arr[i][j] = '.' ;
                arr[i][m-1] = '#' ;
            }
            else
                if (i%2 != 0 && arr [i-2][0] == '.') {
                    arr [i][j] = '.' ;
                    arr [i][0] = '#' ;
                }
                else if (i%2 != 0 && arr [i-2][0] == '#') {
                arr [i][j] = '.' ;
                arr [i][m-1] = '#' ;
            }
        }
    }
    for (int i = 0 ; i < n ; ++i) {
        for (int j = 0 ; j < m; ++j) {
            cout << arr [i][j]  ;
        }
        cout << "\n" ;
    }
}

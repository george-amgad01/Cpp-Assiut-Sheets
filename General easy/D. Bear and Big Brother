#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll a , b ; cin >> a >> b ;
    ll cnt = 0 ;
    for (ll i = 0 ; i <= 10 ; i++) {
        if (a > b) {
            break;
        }
        a *= 3 ; b*= 2 ;
        cnt++ ;
    }
    cout << cnt ;
}

int main() {
    George;
    int t =1 ;
    //cin >> t;
    while (t--) {
        solve();
    }
}

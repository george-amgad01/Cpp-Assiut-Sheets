#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll r ,c ; cin >> r >> c ;
    char arr[r][c] ;
    ll cnt = 0 ; ll cnt2 = 0 ;
    ll found = 0 ;
    for (ll i = 0 ; i < r ; i++) {
        for (ll j = 0 ; j < c ; j++) {
            cin >> arr[i][j];
        }
    }
    for (ll i = 0 ; i < r ; i++) {
        cnt2 = 0;
        for (ll j = 0 ; j < c ; j++) {
            if (arr[i][j] == '.') {
                cnt2 +=1 ;
            }
            else if (arr[i][j] == 'S') {found =1; break;}
        }
        if (found) {
            cnt2 = 0 ;
            found = 0 ;
        }
        else {
            for (ll k = 0 ; k < c ; k++) {
                arr[i][k] = 'm' ;
            }
            cnt += cnt2 ;
            cnt2 = 0 ;

        }
    }
    for (ll j = 0 ; j < c ; j++){
        for (ll i = 0 ; i < r ; i++) {
            if (arr[i][j] == '.') {
                cnt2 +=1 ;
                arr[i][j] = 'm' ;
            }
            else if (arr[i][j] == 'S') {found =1 ; break ;}
        }
        if (found) {
            cnt2 = 0 ;
            found = 0 ;
        }
        else {
            cnt += cnt2 ;
            cnt2 = 0 ;
        }
    }
    cout << cnt ;
}

int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}



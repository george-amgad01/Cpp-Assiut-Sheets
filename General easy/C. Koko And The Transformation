#include <iostream>
#include <bits/stdc++.h>
#define ll long long
using namespace std ;
int main () {
    ll n , m ; cin >> n >> m ;
    ll arr[n] , arr2[m] ;
    ll cnt = 0 ; ll cnt2 = 0 ;
    for (int i = 0 ; i < n ; ++i) {
        cin >> arr[i] ;
        cnt += arr[i] ;
    }
    for (int i = 0 ; i < m ; ++i) {
        cin >> arr2[i] ;
        cnt2 += arr2[i] ;
    }
    if (cnt == cnt2) cout << "Yes" ;
    else cout << "No" ;

}

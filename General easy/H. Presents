#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
ll n ; cin >> n ;
    ll arr[n] ;
    for(ll i = 0 ; i < n ; i++) {
        cin >> arr[i];
    }
    for(ll i = 0 ; i < n ; i++) {
        ll res = find(arr,arr+n,i+1) -arr ;
        cout << res +1 << " ";
    }
}

int main() {
    George;
    int t =1  ;
    //cin >> t;
    while (t--) {

        solve();
    }
}

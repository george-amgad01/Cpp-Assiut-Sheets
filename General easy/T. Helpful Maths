#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    string s; cin >> s;
    ll n = s.size() ; ll l = (n/2) +1 ;
    string arr[l] ;
    ll j = 0 ;
    for (ll i = 0 ; i < l ; i++) {
        arr[i] = s[j];
        j+=2 ;
    }
    sort (arr, arr + l);
    for (ll i = 0 ; i < l ; i++) {
        if (i == l-1 ) {cout << arr[i];}
        else {
        cout << arr[i] << "+";
    }
    }
}

int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}

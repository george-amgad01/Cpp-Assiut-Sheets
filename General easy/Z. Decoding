#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n ; cin >> n ;
    string s ; cin >> s ;
    string s2 = s ;
    ll median = (s.size() -1) / 2 ;
    ll n1 = median -1 ; ll n2 = median +1 ;
    for (ll i = 0 ; i < n ; i++) {
        if (i==0) {
            s2[median] = s[i] ;
        }
        else if (n%2!= 0) {
            if (i%2 != 0) {
                s2[n1]=s[i];n1 -=1;
            }
            else {s2[n2] = s[i] ; n2 +=1 ;}
        }
        else {
            if (i % 2 != 0) {
                s2[n2] = s[i] ; n2 +=1;
            }
            else {s2[n1] = s[i] ; n1 -=1;}
        }
    }
    cout << s2 ;
}
int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n ; cin >> n ;
    ll arr[n] ;
    ll cnt = 0 ; ll cnt2 = n-1;
    ll s =0 ; ll d = 0 ;
    for (int i=0; i < n ; ++i) {
        cin >> arr[i] ;
    }
    for (int i = 0 ; i< n; ++i) {

        if ( cnt > cnt2) {break;}

        if (arr[cnt] > arr[cnt2]) {s +=arr[cnt]; cnt+=1 ;}
        else {s+=arr[cnt2] ; cnt2-=1 ;}

        if (cnt > cnt2) {break;}

        if (arr[cnt] > arr[cnt2]) {d +=arr[cnt]; cnt+=1 ;}
        else {d+=arr[cnt2] ; cnt2-=1 ;}
    }
    cout << s << " " << d ;

}
int main() {
    George;
    int t = 1;
    // cin >> t;

    while (t--)
        solve();

}

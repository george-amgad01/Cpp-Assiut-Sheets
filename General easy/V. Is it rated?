#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n;cin >> n;
    ll arr[n][2] ;
    bool found =0 ; bool found2 = 0 ;
    for(ll i=0;i<n;i++) {
        cin >> arr[i][0] >> arr[i][1];
    }
    for(ll i=0;i<n;i++) {
        if (arr[i][0] != arr[i][1]) {found =1 ; break;}
    }
    for(ll i=0;i<n;i++) {
        if (i+1 >= n) {break;}
        else {
            if (arr[i][0] < arr[i+1][0]) {found2 =1 ; break;}
        }
    }
    if (found){cout << "rated" ;}
    else if (found2){cout << "unrated";}
    else { cout << "maybe";}
    }


int main() {
    George;
    int t = 1 ;
    //cin >> t;

    while (t--)
        solve();

}

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n ; cin >> n ;
    vector<ll> v ;
    ll res = 0 ;
    for (ll i = 1 ; i*i <= n ; i++) {
        if (n % i == 0 && i*i != n) {
            v.push_back(i);
            v.push_back(n/i);
        }
        if (i*i == n ) {
            v.push_back(i);
        }
    }
    for (ll i = 0 ; i < v.size() ; i++) {
        res += v[i];
    }
    cout << res ;
}

int main() {
    George;
    int t =1  ;
    //cin >> t;

    while (t--) {
        solve();
    }
}

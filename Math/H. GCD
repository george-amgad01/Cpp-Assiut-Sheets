#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
ll gcd ( ll a , ll b ) {
    while (b > 0) {
        a%= b ;
        swap(a,b) ;
    }
    return a;
}

ll lcm ( ll a , ll b ) {
    return (a / gcd( a,b)) * b ;
}

    void solve() {
    ll a , b ;
    cin >> a >> b ;
    cout << gcd(a,b) << " " << lcm(a,b) ;
}

int main() {
    George;
    int t = 1 ;
    //cin >> t;

    while (t--) {
        solve();
    }
}

void max ( ll n , vector<ll> v ) {
    ll max = v[0] ;
    for (ll i = 1 ; i < n ; i++ ) {
        if (v[i] > max) { max = v[i] ; }
    }
    cout << "The maximum number : " << max << nl ;
}
void min (ll n , vector<ll> v ) {
    ll min = v[0] ;
    for (ll i = 1 ; i < n ; i++ ) {
        if (v[i] < min) { min = v[i] ; }
    }
    cout << "The minimum number : " << min << nl ;
}
void prime_count (ll n , vector<ll> v) {
    ll cnt = 0 ;
    bool f = 0 ;
    for (ll i = 0 ; i < n ; i++ ) {
        if (v[i] < 2 ) {continue;}
        f = 0 ;
        for (ll x = 2 ; x*x <= v[i] ; x++ ) {
            if (v[i] % x == 0) {
                f = 1 ;
                break;
            }
        }
        if (!f) {cnt++ ;}
    }
    cout <<"The number of prime numbers : " << cnt << nl;
}
void palindrome ( ll n , vector<ll> v ) {
    ll num = 0 , rem = 0 , cnt = 0 ;
    for (ll i = 0 ; i < n ; i++ ) {
        ll goal = v[i] ;
        num = 0 ;
        rem = 0 ;
        while (goal > 0 ) {
            rem = goal % 10;  // 125   5 2 1
            num = (num*10 ) + rem ;   // 5 2 1
            goal /= 10 ;
        }
        if (v[i] == num) {cnt ++;}
    }
    cout << "The number of palindrome numbers : " << cnt << nl;
}


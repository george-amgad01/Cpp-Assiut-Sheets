#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)

void max_min (ll n , vector<ll>& v) {
    ll mx = 0 , mn = 0 ;
    for (ll i = 0 ; i < n ; i++) {
        cin >> v[i] ;
    }
    mx = v[0] ; mn = v[0] ;
    for (ll i = 0 ; i < n ; i++) {
        if (v[i] < mn) mn = v[i] ;
        if (v[i] > mx) mx = v[i] ;
    }
    cout << mn << " " << mx ;

}

int main() {
    George;
    int t =1  ;
    //cin >> t;
    while (t--) {
        ll n ;
        cin >> n ;
        vector <ll> v(n) ;
        max_min(n,v) ;

    }
}

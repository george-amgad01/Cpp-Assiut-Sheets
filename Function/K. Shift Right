#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define dd double
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve(){
    ll n , x ;
    cin >> n >> x ;
    vector <ll> v(n) ;
    ll shift = x % n , num = 0 ;
    for (ll i = 0 ; i < n ; i++) {
        cin >> v[i];
    }
    for (ll i = 0 ; i < n ; i++) {
        if (shift > 0 ) {
            num = v[n-1] ;
            v.pop_back() ;
            v.insert(v.begin(),num) ;
            shift-- ;
        }
    }
    for (ll i = 0 ; i < n ; i++) {
        if (i == n-1) cout << v[i] ;
        else cout << v[i] << " " ;
    }
}

int main() {
    George;
    int t =1  ;
    //cin >> t;
    while (t--) {
        solve();

    }
}

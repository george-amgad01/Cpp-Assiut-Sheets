#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define dd double
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve(ll n , vector<double> & v) {
    cout << fixed << setprecision(7) ;
    dd avg = 0 ;
    for (ll i = 0 ; i < n ; i++) {
        cin >> v[i] ;
        avg += v[i] ;
    }
    cout << avg / n ;
}

int main() {
    George;
    int t =1  ;
    //cin >> t;
    while (t--) {
        ll n;
        cin >> n ;
        vector<double> v (n);
        solve(n , v);


    }
}

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll s , n ; cin >> s >> n ;
    ll arr [n] , arr2[n] , target[n] ;
    ll found = 1;
    for (ll i = 0 ; i < n ; i++) {
        cin >> arr [i] >> arr2[i];
        target[i] = arr [i];
    }
    sort(target , target + n) ;
    for (ll i = 0 ; i < n ; i++) {
        if (s > target[i] & target [i] > 0 ) {
            ll idx = find(arr,arr+n,target[i]) - arr;
            s += arr2[idx] ;
            arr2[idx] = 0 ;
            arr [idx] = 0 ;
        }
        else {found = 0 ;}
    }
    if (found) cout << "YES" << nl ;
    else cout << "NO" << nl ;
}
int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}



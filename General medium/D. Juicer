#include <iostream>
#include <bits/stdc++.h>
#define ll long long
using namespace std ;
int main () {
    ll n , b , d  ; cin >> n >> b >> d  ;
    ll arr [n]  ;
    ll cnt = 0 ;
    ll cnt2 = 0 ;
    for (int i = 0 ; i < n ; ++i ) {
        cin >> arr[i] ;
    }
    for (int i = 0 ; i < n ; ++i ) {
        if (arr[i]<= b) {
            cnt += arr[i] ;
            if (cnt > d ) { cnt2+=1 ; cnt = 0 ;}
        }
    }
    cout << cnt2 ;
}

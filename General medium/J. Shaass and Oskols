#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n; cin >> n;
    vector<ll> v(n);
    for(ll i=0;i<n;i++) {
        cin >> v[i];
    }
    ll m ; cin >> m;
    vector<vector<ll>> v2 (m,vector <ll>(2));
    for(ll i=0;i<m;i++) {
        cin >> v2[i][0] >> v2[i][1];
    }
    for(ll i=0;i<m;i++) {
        ll ind = (v2[i][0]) -1 ;
        ll left = v2[i][1] -1;
        ll right = v[ind] - v2[i][1] ;
        if (ind-1 >= 0) {v[ind-1] += left;}
        if (ind+1 < n) {v[ind+1] += right;}
        v[ind] = 0 ;
    }
    for(ll i=0;i<n;i++) {
        cout << v[i] << nl ;
    }
}
int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}

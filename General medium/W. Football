#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n; cin >> n;
    string s , s2  ;
    ll cnt = 0 ; ll cnt2 = 0 ;
    vector<string> v(n);
    for (ll i = 0; i < n; i++) {
        cin >> v[i];
        s = v[0];
        if (v[i] != s ) {s2 = v[i] ; cnt2 += 1;}
        else {
            cnt +=1 ;
        }
    }
    if (cnt > cnt2 ) cout << s ;
    else cout << s2 ;
}
int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n ; cin >> n;
    vector<ll> v(n);
    ll cnt = 0 ;
    for(ll i=0;i<n;i++) {
        cin >> v[i];
        if (abs(v[i]) % 2 == 1){
        cnt+=1;
    }

    }
    ll c = cnt/2 ; ll r = cnt / 2 ;
    for(ll i=0;i<n;i++) {
        if (v[i] % 2 == 0) {
            v[i] = v[i] / 2;
        }
        else if (v[i] %2 != 0 && c > 0) {
            if (v[i] > 0 ) {
                v[i] = (v[i] / 2) +1 ;
            }
            else {
                v[i] = (v[i] / 2)  ;
            }
            c-=1;

        }
        else if (v[i] %2 !=0 && r > 0) {
            if (v[i] > 0 ) {
                v[i] = (v[i] / 2) ;
            }
            else {
                v[i] = (v[i] / 2 ) -1 ;
            }
            r-=1;
        }
    }
    for(ll i=0;i<n;i++) {

        cout << v[i] << nl  ;
    }
}

int main() {
    George;
    int t = 1;
    //cin >> t;
    while (t--) {

        solve();
    }
}

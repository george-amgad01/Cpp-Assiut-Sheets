#include <iostream>
#include <bits/stdc++.h>
#define ll long long
using namespace std ;
int main () {
    string s1 = "qwertyuiop " , s2 = "asdfghjkl;" , s3 = "zxcvbnm,./" ;
    char c ; cin >> c;
    string w ; cin >> w ; string w2 = "" ;
    ll len = w.size() ; ll n = 0 ;
    for (int i = 0 ; i < len ; ++i) {
        if (c == 'R') {
            if (s1.find(w[i]) != string::npos ) {n = s1.find(w[i]); w2 += s1[n-1] ;}
            else if (s2.find(w[i]) != string::npos ) {n = s2.find(w[i]);w2 += s2[n-1] ;}
            else if (s3.find(w[i]) != string::npos ) {n = s3.find(w[i]);w2 += s3[n-1] ;}
        }
        if (c == 'L') {
            if (s1.find(w[i]) != string::npos ) {n = s1.find(w[i]); w2 += s1[n+1] ;}
            else if (s2.find(w[i]) != string::npos ) {n = s2.find(w[i]); w2 += s2[n+1] ;}
            else if (s3.find(w[i]) != string::npos ) {n = s3.find(w[i]); w2 += s3[n+1] ;}
        }
    }
    cout << w2;

}

#include <bits/stdc++.h>
using namespace std;
#define ll long long
#define nl '\n'
#define George ios_base::sync_with_stdio(false); cin.tie(0);cout.tie(0)
void solve() {
    ll n; cin >> n;
    vector<char> v(n);
    vector<ll> v2 (n);
    vector<ll> v3 ;
    ll right = -1 ; ll left = -1; ll res = 0 ;
    for (ll i = 0; i < n; i++) {
        cin >> v[i];
    }
    for (ll i = 0; i < n; i++) {
        cin >> v2[i];
    }
    for (ll i = 0; i < n; i++) {
        if (v[i] == 'R') {right = v2[i]; }
        else if (v[i] == 'L') {left = v2[i]; }
        if (right != -1 && left != -1 && right <= left) {
            res = (left - right) / 2 ;
            v3.push_back(res) ;
            left = -1 ;
            right = -1 ;
        }
    }
    if (v3.size() == 0) {
        cout << -1 ;
    }
    else {
        cout << *min_element(v3.begin(), v3.end()) ;
    }

}
int main() {
    George;
    int t = 1;
    //cin >> t;

    while (t--)
        solve();

}
